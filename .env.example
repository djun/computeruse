# Core OpenRouter clients
USE_OPENROUTER=true
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-opus-4.5

# Planner (falls back to OpenRouter key/base if left blank)
PLANNER_API_KEY=
PLANNER_BASE_URL=https://openrouter.ai/api/v1
PLANNER_MODEL=anthropic/claude-3.5-sonnet

# Reflector / verifier (falls back to OpenRouter key/base if left blank)
ENABLE_REFLECTION=true
REFLECTOR_API_KEY=
REFLECTOR_BASE_URL=https://openrouter.ai/api/v1
REFLECTOR_MODEL=openai/gpt-5.1

# Embeddings (recommended ON in production for fast-path + vector retrieval)
ENABLE_EMBEDDINGS=true
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Execution toggles
EXECUTION_PROFILE=hybrid   # local_gui | remote_cli | hybrid
ENABLE_HID=false          # true to send physical mouse/keyboard events
ENABLE_SEMANTIC=true      # Semantic path (AX on macOS, UIA/Phantom Mode on Windows)
ENABLE_SHELL=false        # sandboxed shell under .agent_shell
WINDOWS_CYBORG_MODE=true  # Windows-only: avoid CDP; prefer UIA/HID/Vision when Chrome blocks remote debugging
WINDOWS_AUTO_ELEVATE=true # Windows-only: request UAC elevation when ENABLE_HID=true
ENABLE_VISUAL_DETECTOR=false      # Optional object detector for visual grounding (ultralytics/grounding-dino style)
VISUAL_DETECTOR_BACKEND=auto      # auto | none | ultralytics
VISUAL_DETECTOR_MODEL=             # e.g. path/to/ui-detector.pt (ultralytics)
VISUAL_DETECTOR_CONFIDENCE=0.35
VISUAL_DETECTOR_IOU=0.45
VISUAL_DETECTOR_MAX_DETECTIONS=120
ENABLE_SENSITIVE_VISION_REDACTION=true  # Blur sensitive OCR regions before frames are sent to model APIs
VISION_REDACTION_MIN_OCR_CONF=35
VISION_REDACTION_BLUR_PADDING_PX=4
ENABLE_HITL_PROMPT=true          # Ask for [y/N] approval when policy marks an action as high risk
STRICT_STEP_COMPLETION=true
STRICT_POST_ACTION_STATE_CHANGE=true
LOG_LEVEL=INFO
ENCODE_FORMAT=JPEG
ENABLE_DEBUG_DASHBOARD=false
DEBUG_DASHBOARD_HOST=127.0.0.1
DEBUG_DASHBOARD_PORT=8765

# Procedural memory / fast-path (recommended for production)
ENABLE_FAST_PATH_SKILLS=true
FAST_PATH_MIN_VECTOR_SCORE=0.78
FAST_PATH_MIN_KEYWORD_SCORE=4.0
DYNAMIC_SKILL_MIN_ACTIONS=3
DYNAMIC_SKILL_CAPTURE_WINDOW=20
ENABLE_CHROMA_SKILLS=true
CHROMA_SKILLS_COLLECTION=procedural_skills
CHROMA_PERSIST_DIR=.agent_memory/chroma

# Reasoning controls (optional)
REASONING_EFFORT=
REASONING_MAX_TOKENS=

# Loop limits and pacing
MAX_STEPS=50
MAX_FAILURES=5
MAX_WALL_CLOCK_SECONDS=0
VERIFY_DELAY_MS=200
SETTLE_DELAY_MS=500
SSIM_CHANGE_THRESHOLD=0.985

# Browser safety
BROWSER_SCRIPT_TIMEOUT_S=8
BROWSER_NAVIGATION_TIMEOUT_S=12

# Shell sandbox settings
SHELL_WORKSPACE_ROOT=.agent_shell
SHELL_MAX_RUNTIME_S=10
SHELL_MAX_OUTPUT_BYTES=65536
# Comma-separated allowlist (basenames) to extend defaults (platform-specific).
# macOS/Linux example: ls,echo,grep,wc,git
# Windows example: dir,Get-ChildItem,Get-Content,Select-String,copy,move,del
SHELL_ALLOWED_COMMANDS=

# Persistence
MEMORY_ROOT=.agent_memory
